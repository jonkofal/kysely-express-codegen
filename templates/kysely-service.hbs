import { Database, {{pascalCase name}}, {{pascalCase name}}Filter } from '../db/types.js';
import { Kysely } from 'kysely'

export default class {{pascalCase name}}Service {

constructor(private database: Kysely<Database>) {}

    async selectOne(id: string) {
        const retVal = await this.database
            .selectFrom('{{name}}')
            .where('id', '=', id)
            .selectAll()
            .executeTakeFirst();
        return retVal;
    }
    async selectAll() {
        const retVal = await this.selectWithFilter({});
        return retVal;
    }
    async selectWithFilter(filter: {{pascalCase name}}Filter) {
        let query = this.database
            .selectFrom('{{name}}')
            .selectAll();
{{#each fields}}
        // query = whereOptional(query, "{{name}}", filter.{{name}});
        if (filter.{{name}}) {
            query = query.where('{{name}}', '=', filter.{{name}});
        }
{{/each}}
        const retVal = await query.execute();
        return retVal
    }
    async insert({{camelCase name}}: {{pascalCase name}}) {
        const retVal = await this.database.insertInto('{{name}}').values({{camelCase name}}).returningAll().executeTakeFirstOrThrow();
        return retVal;
    }
    async update({{camelCase name}}: {{pascalCase name}}) {
        const retVal = await this.database.updateTable('{{name}}').set({{camelCase name}}).where('id', '=', {{camelCase name}}_id).execute();
        return retVal;
    }
    async delete(id: string) {
        const retVal = await this.database.deleteFrom('{{name}}').where('id', '=', id).execute();
        return retVal;
    }
}
