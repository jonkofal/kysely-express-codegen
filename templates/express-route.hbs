{{name}}Router.get('/:id', async ( req: Request, res: Response, next: NextFunction ) => {
    try {
        const database = req.app.locals.database;
        const { id } = req.params;
        const result = await database.selectFrom('{{name}}').where('id', '=', id).selectAll().executeTakeFirst();
        res.json(result);
    } catch (error) {
        next(error);
    }
});
{{name}}Router.post('/', async ( req: Request, res: Response, next: NextFunction ) => {
    try {
        const database = req.app.locals.database;
        const result = await database.insertInto('{{name}}').values(req.body).returningAll().executeTakeFirstOrThrow();
        res.json(result);
    } catch (error) {
        next(error);
    }
});
{{name}}Router.put('/', async ( req: Request, res: Response, next: NextFunction ) => {
    try {
        const database = req.app.locals.database;
        const { id } = req.body;
        const result = await database.updateTable('{{name}}').set(req.body).where('id', '=', id).execute();
        res.json("OK");
    } catch (error) {
        next(error);
    }
});
{{name}}Router.delete('/:id', async ( req: Request, res: Response, next: NextFunction ) => {
    try {
        const database = req.app.locals.database;
        const { id } = req.params;
        const result = await database.deleteFrom('{{name}}').where('id', '=', id).execute();
        res.json(result);
    } catch (error) {
        next(error);
    }
});

export default {{name}}Router;