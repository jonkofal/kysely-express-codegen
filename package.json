{
  "name": "@ampsy/kysely-express-codegen",
  "version": "0.0.2",
  "description": "npx function to dump a postgres database to express routes, using the kysely library",
  "repository": {
    "type": "git",
    "url": "https://github.org/jonkofal/kysely-express-codegen"
  },
  "license": "ISC",
  "author": "Zane Ray",
  "type": "module",
  "main": "bin/kysely-express-codegen.js",
  "bin": {
    "@ampsy/kysely-express-codegen": "bin/kysely-express-codegen.js",
    "kysely-express-codegen": "bin/kysely-express-codegen.js"
  },
  "directories": {
    "doc": "doc",
    "test": "test"
  },
  "scripts": {
    "build": "tsc",
    "dev": "export $(grep -v '^#' .env | xargs) && ./bin/kysely-express-codegen.js"
  },
  "dependencies": {
    "optimist": "^0.5.2",
    "pg": "^8.20.0",
    "prompt": "^1.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "express": "^5.2.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
